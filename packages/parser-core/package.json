{
  "name": "@firela/parser-core",
  "version": "1.0.0",
  "description": "Core parser interfaces and utilities for financial institution statement parsing",
  "keywords": ["parser", "csv", "bank", "statement", "beancount", "firela"],
  "author": "Firela Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fire-la/parsers",
    "directory": "packages/parser-core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "decimal.js": "^10.6.0"
  },
  "peerDependencies": {
    "csv-parse": "^5.5.0",
    "chrono-node": "^2.9.0",
    "iconv-lite": "^0.6.0",
    "jschardet": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "chrono-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "chrono-node": "^2.9.0",
    "csv-parse": "^5.5.0",
    "eslint": "^8.57.0",
    "iconv-lite": "^0.6.0",
    "jest": "^29.7.0",
    "jschardet": "^3.0.0",
    "ts-jest": "^29.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
